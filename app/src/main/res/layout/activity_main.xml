<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    tools:context=".Controller.MainActivity">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="226dp"
        android:layout_height="173dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/hp_logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/btnChar"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_margin="10dp"
        android:background="@drawable/botao_menu"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.16"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.38">

        <ImageView
            android:id="@+id/imgChar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/harry" />

        <TextView
            android:id="@+id/tvChar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Personagem"
            android:textColor="#D4AF37"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCharDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="por ID"
            android:textColor="#888888" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnTeacher"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_margin="10dp"
        android:background="@drawable/botao_menu"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.84"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.38">

        <ImageView
            android:id="@+id/imgTeacher"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/minerva" />

        <TextView
            android:id="@+id/tvTeacher"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Professores"
            android:textColor="#D4AF37"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTeacherDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="da escola"
            android:textColor="#888888" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnHouse"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_margin="10dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/botao_menu"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.16"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.67">

        <ImageView
            android:id="@+id/imgHouse"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/house" />

        <TextView
            android:id="@+id/tvHouse"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estudantes"
            android:textColor="#D4AF37"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHouseDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="por casa"
            android:textColor="#888888" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnSpell"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_margin="10dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/botao_menu"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.84"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.67">

        <ImageView
            android:id="@+id/imgSpell"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/spell" />

        <TextView
            android:id="@+id/tvSpell"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Feitiços"
            android:textColor="#D4AF37"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSpellDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="grimório"
            android:textColor="#888888" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnExit"
        android:layout_width="168dp"
        android:layout_height="44dp"
        android:layout_margin="10dp"
        android:background="@drawable/botao_menu"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.925">

        <TextView
            android:id="@+id/tvExit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sair do aplicativo"
            android:textColor="#888888" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>