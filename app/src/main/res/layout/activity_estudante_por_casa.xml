<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101010"
    tools:context=".Controller.EstudantePorCasa">

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/harrypf"
        android:text="Estudantes por Casa"
        android:textColor="#D4AF37"
        android:textSize="34dp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- CARD DAS CASAS -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardCasas"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="16dp"
        app:cardBackgroundColor="#1B1B1B"
        app:cardCornerRadius="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtTitulo">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- TEXTO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/harrypf"
                android:text="Selecione uma Casa"
                android:textColor="#E8D9A8"
                android:textSize="28dp"
                android:textStyle="bold"/>

            <!-- ESPAÇO -->
            <Space
                android:layout_width="wrap_content"
                android:layout_height="16dp"/>

            <!-- RADIO GROUP -->
            <RadioGroup
                android:id="@+id/radioGroupCasas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:weightSum="4">

                <!-- GRIFINÓRIA -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/imgGrifinoria"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:padding="8dp"
                        android:src="@drawable/grifnoria"/>

                    <RadioButton
                        android:id="@+id/rbGrifinoria"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="#D4AF37" />

                    <TextView
                        android:id="@+id/txtGrifinoria"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grifinória"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- SONSERINA -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/imgSonserina"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:padding="8dp"
                        android:src="@drawable/sonserina"/>

                    <RadioButton
                        android:id="@+id/rbSonserina"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="#D4AF37"/>

                    <TextView
                        android:id="@+id/txtSonserina"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sonserina"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- LUFA-LUFA -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/imgLufa"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:padding="8dp"
                        android:src="@drawable/lufalufa"/>

                    <RadioButton
                        android:id="@+id/rbLufa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="#D4AF37"/>

                    <TextView
                        android:id="@+id/txtLufa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lufa-Lufa"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- CORVINAL -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/imgCorvinal"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:padding="8dp"
                        android:src="@drawable/corvinal"/>

                    <RadioButton
                        android:id="@+id/rbCorvinal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="#D4AF37"/>

                    <TextView
                        android:id="@+id/txtCorvinal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Corvinal"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"/>
                </LinearLayout>

            </RadioGroup>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- RECYCLERVIEW -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerEstudantes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardCasas"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_estudante"/>

</androidx.constraintlayout.widget.ConstraintLayout>